{
  "name": "@chazepps/homebridge-hejhome",
  "displayName": "Hejhome",
  "version": "2.0.1",
  "private": false,
  "description": "The Hejhome plugin allows you to access your Hejhome device(s) from HomeKit.",
  "author": {
    "name": "Chaz",
    "email": "chaz.epps@gmail.com",
    "url": "https://github.com/chazepps"
  },
  "contributors": [
    {
      "name": "Chaz",
      "url": "https://github.com/chazepps"
    }
  ],
  "license": "ISC",
  "homepage": "https://github.com/chazepps/homebridge-hejhome#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/chazepps/homebridge-hejhome.git"
  },
  "bugs": {
    "url": "https://github.com/chazepps/homebridge-hejhome/issues"
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "hejhome",
    "hej",
    "hub",
    "lightstrip",
    "lights",
    "motion",
    "outlet",
    "smart-home",
    "homekit",
    "헤이홈"
  ],
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/chazepps"
    }
  ],
  "icon": "https://raw.githubusercontent.com/chazepps/homebridge-hejhome/main/branding/icon.png",
  "main": "dist/index.js",
  "type": "module",
  "files": [
    "dist",
    "homebridge-ui",
    "branding",
    "config.schema.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": "^22.12.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0"
  },
  "scripts": {
    "build": "rimraf ./dist && tsc",
    "docs:generate": "node tools/docs/generate-project-structure.mjs",
    "docs:check": "node tools/docs/inventory-doc-harness.mjs --check && node tools/docs/validate-doc-harness.mjs && node tools/docs/generate-project-structure.mjs --check",
    "homebridge:dev": "homebridge -P . --strict-plugin-resolution -U ./test/hbConfig -D -Q",
    "homebridge:ui": "node tools/homebridge/run-dev-ui.mjs",
    "homebridge:ui:tmux": "tmux kill-session -t homebridge-hejhome 2>/dev/null || true; tmux new-session -d -s homebridge-hejhome -c \"$PWD\" 'unset npm_config_prefix; export NVM_DIR=\"$HOME/.nvm\"; if [ -s \"$NVM_DIR/nvm.sh\" ]; then . \"$NVM_DIR/nvm.sh\" && nvm use --silent >/dev/null; fi; npm run build && npm run homebridge:ui'",
    "homebridge:ui:stop": "tmux kill-session -t homebridge-hejhome",
    "homebridge:pi:verify": "node tools/homebridge/verify-pi-runtime.mjs",
    "lint": "eslint . --max-warnings=0",
    "prepublishOnly": "npm run verify",
    "test": "vitest run",
    "test:ui": "playwright test",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run typecheck && npm test && npm run test:ui && npm run build && npm run docs:check",
    "watch": "npm run build && npm link && nodemon"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.2.3",
    "mqtt": "^5.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "homebridge": "^2.0.2",
    "homebridge-config-ui-x": "^5.23.0",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
