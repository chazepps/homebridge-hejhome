{
  "pluginAlias": "Hejhome",
  "pluginType": "platform",
  "singular": true,
  "customUi": true,
  "customUiPath": "./homebridge-ui",
  "strictValidation": true,
  "schema": {
    "type": "object",
    "required": [
      "name"
    ],
    "additionalProperties": false,
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "Hejhome"
      },
      "auth": {
        "title": "Hejhome Login State",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "identifier": {
            "title": "전화번호 or 이메일",
            "type": "string"
          },
          "sessionConfigured": {
            "title": "Session Configured",
            "type": "boolean",
            "default": false
          }
        }
      },
      "debug": {
        "title": "Debug Logging",
        "type": "boolean",
        "default": false
      }
    }
  }
}
